{
  "name": "svelte-time",
  "version": "2.1.0",
  "license": "MIT",
  "description": "Svelte component and action library for formatting timestamps and durations using day.js",
  "author": "Eric Liu (https://github.com/metonym)",
  "type": "module",
  "svelte": "./src/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json --config ./vite.config.ts",
    "package": "bun --run dlz",
    "lint": "biome check --write .",
    "lint:changed": "biome check --write --changed --since=master --no-errors-on-unmatched .",
    "upgrade-examples": "bun scripts/upgrade-examples.ts",
    "generate-locales": "bun scripts/generate-locales.ts"
  },
  "dependencies": {
    "dayjs": "^1.11.21"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.0",
    "dlz": "^0.1.3",
    "github-markdown-css": "^5.9.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "marked-base-url": "^1.1.10",
    "marked-highlight": "^2.2.4",
    "shiki": "^4.3.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metonym/svelte-time.git"
  },
  "homepage": "https://metonym.github.io/svelte-time/",
  "bugs": "https://github.com/metonym/svelte-time/issues",
  "keywords": [
    "svelte",
    "dayjs",
    "time formatter",
    "timestamp",
    "relative",
    "ago",
    "duration",
    "timer",
    "stopwatch"
  ]
}
